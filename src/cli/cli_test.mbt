///|
test "parse_cli_args --log=path" {
  let args = ["whirlwind", "--log=/tmp/whirlwind.log"]
  let parsed = @cli.parse_cli_args(args, file_exists_mock)
  match parsed {
    Run(log_path~, ..) =>
      inspect(log_path, content="Some(\"/tmp/whirlwind.log\")")
    _ => panic()
  }
}

///|
test "parse_cli_args --log path" {
  let args = ["whirlwind", "--log", "/tmp/whirlwind.log"]
  let parsed = @cli.parse_cli_args(args, file_exists_mock)
  match parsed {
    Run(log_path~, ..) =>
      inspect(log_path, content="Some(\"/tmp/whirlwind.log\")")
    _ => panic()
